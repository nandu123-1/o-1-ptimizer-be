GEMINI_API_KEY=<your_gemini_api_key>

# Optional: comma-separated pool for automatic failover on quota exhaustion.
GEMINI_API_KEYS=<key_1>,<key_2>

SERPER_API_KEY=<optional_serper_key_for_web_research>

# Comma separated list of frontend origins permitted to call the API.
# Defaults to http://localhost:3000,http://127.0.0.1:3000 when unset.
DSA_TUTOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional overrides for the dev server.
DSA_TUTOR_API_PORT=8000
DSA_TUTOR_LOG_LEVEL=INFO

# Set to "1" to use the multi-agent CrewAI pipeline as the primary optimizer.
# Defaults to the direct single-shot Gemini path (faster, lower quota cost).
DSA_TUTOR_USE_CREW=0
